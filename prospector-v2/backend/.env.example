# Banco de dados - escolha UMA opção:

# Opção 1: SQLite (local, sem setup extra)
DB_PATH=./data/prospector.db

# Opção 2: PostgreSQL (produção/Railway)
# DATABASE_URL=postgresql://user:password@localhost:5432/prospector

# JWT - troque em produção!
JWT_SECRET=prospector-dev-secret-change-in-production

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Porta do servidor (Railway define automático)
PORT=3001

# Admin seed (opcional - usado pelo npm run seed)
# SEED_EMAIL=admin@admin.com
# SEED_SENHA=123456
# SEED_NOME=Admin
