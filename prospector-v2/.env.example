# Prospector v2 - Variáveis de ambiente

# Porta do servidor (default: 3001)
PORT=3001

# Segredo para assinar os tokens JWT (gerar um hash forte)
JWT_SECRET=coloque-um-segredo-forte-aqui

# URL do frontend (para CORS em desenvolvimento)
FRONTEND_URL=http://localhost:5173

# Caminho do banco SQLite (default: ./data/prospector.db)
DB_PATH=./data/prospector.db
